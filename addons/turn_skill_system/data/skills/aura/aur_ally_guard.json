{
  "version": 1,
  "id": "aur_ally_guard",
  "type": "aura",
  "name": "队友：守护光环",
  "desc": "为全体友军提供减伤（进入时获得 BUFF，离开时移除）。",
  "tags": ["BUFF"],
  "targeting": {
    "needs_primary": false,
    "primary_role": "cell",
    "rule": "single_cell",
    "params": {}
  },
  "aura": {
    "range": {
      "rule": "ally_all",
      "params": {}
    },
    "on_enter": [
      {
        "kind": "apply_buff",
        "params": {
          "buff_id": "buff_dmg_reduce_20p",
          "scope": "target"
        }
      }
    ],
    "on_exit": [
      {
        "kind": "remove_buff",
        "params": {
          "buff_id": "buff_dmg_reduce_20p",
          "scope": "target",
          "remove_scope": "ALL"
        }
      }
    ]
  }
}

