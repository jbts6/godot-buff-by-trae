{
  "schema_version": 1,
  "dataset_id": "base_demo",
  "load_order": [
	"enums",
	"stat_defs",
	"buff_defs",
	"equipment",
	"set_bonus",
	"skill_defs",
    "damage_pipeline"
  ],
  "build": {
	"fingerprint": {
	  "method": "content_hash",
	  "include": [
		"manifest",
		"enums",
		"stat_defs",
		"buff_defs",
		"equipment",
		"set_bonus",
		"skill_defs",
        "damage_pipeline"
	  ]
	}
  },
  "files": [
	{
	  "id": "manifest",
	  "type": "manifest",
	  "path": "manifest.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "enums",
	  "type": "enums",
	  "path": "enums.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "stat_defs",
	  "type": "stat_defs",
	  "path": "stat_defs.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "buff_defs",
	  "type": "buff_defs",
	  "path": "buff_defs.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "equipment",
	  "type": "equipment",
	  "path": "equipment.csv",
	  "format": "csv",
	  "required": true
	},
	{
	  "id": "set_bonus",
	  "type": "set_bonus",
	  "path": "set_bonus.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "skill_defs",
	  "type": "skill_defs",
	  "path": "skill_defs.json",
	  "format": "json",
	  "required": true
	},
	{
	  "id": "damage_pipeline",
	  "type": "damage_pipeline",
	  "path": "damage_pipeline.json",
	  "format": "json",
	  "required": true
	}
  ],
  "mod_overrides": {
	"policy": "last_wins_by_id",
	"report_conflicts": true
  }
}
